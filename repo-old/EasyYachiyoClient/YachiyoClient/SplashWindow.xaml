<Window x:Class="EasyYachiyoClient.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyYachiyoClient"
        mc:Ignorable="d"
        Title="启动中..."
        Height="300"
        Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="/resource/window_title_icon.jpg">
    <Window.Resources>
        <DropShadowEffect x:Key="DropShadowEffect"
                          BlurRadius="10"
                          ShadowDepth="3"
                          Opacity="0.3"
                          Direction="270"/>
        
        <!-- 动画资源 -->
        <QuadraticEase x:Key="QuadraticEase" EasingMode="EaseInOut"/>
        <DoubleAnimation x:Key="FadeInAnimation" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        <DoubleAnimation x:Key="FadeOutAnimation" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.3"/>
        <Duration x:Key="ShortAnimationDuration">0:0:0.2</Duration>
        <Duration x:Key="VeryShortAnimationDuration">0:0:0.1</Duration>
        
        <Style x:Key="RoundedPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- 淡蓝色10%透明后景 -->
        <Border 
            Background="#19E0F8FF" 
            CornerRadius="12"
            Margin="10"
            Panel.ZIndex="-1"/>
        <Border 
            Background="Transparent"
            CornerRadius="12"
            Effect="{StaticResource DropShadowEffect}"
            Margin="10"
            RenderOptions.BitmapScalingMode="LowQuality"
            RenderOptions.ClearTypeHint="Enabled">
            <Grid>
                <!-- 标题和图标 -->
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 标题 -->
                    <Border 
                        Grid.Row="0"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,8"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                        <TextBlock 
                            Text="月见八千代"
                            FontSize="20"
                            FontWeight="Medium"/>
                    </Border>
                    
                    <!-- 进度条区域 -->
                    <Border 
                        Grid.Row="2"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,20,0,0">
                        <StackPanel>
                            <!-- 状态文本 -->
                            <TextBlock 
                                x:Name="StatusText"
                                Text="正在初始化..."
                                FontSize="14"
                                FontWeight="Medium"
                                Margin="0,0,0,10"
                                TextAlignment="Center"/>
                            
                            <!-- 进度条 -->
                            <ProgressBar 
                                x:Name="ProgressBar"
                                Height="20"
                                Background="#F0F0F0"
                                Foreground="#0077BE"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Minimum="0"
                                Maximum="100"
                                Value="0"/>
                            
                            <!-- 任务描述文本框 -->
                            <TextBlock 
                                x:Name="TaskDescriptionText"
                                Text="准备中..."
                                FontSize="12"
                                Foreground="#606060"
                                Margin="0,10,0,5"
                                TextAlignment="Center"
                                TextWrapping="Wrap"/>
                            
                            <!-- 副进度条 -->
                            <ProgressBar 
                                x:Name="SecondaryProgressBar"
                                Height="15"
                                Background="#F0F0F0"
                                Foreground="#00A0E9"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Minimum="0"
                                Maximum="100"
                                Value="0"/>
                            
                            <!-- 进度百分比 -->
                            <TextBlock 
                                x:Name="ProgressText"
                                Text="0%"
                                FontSize="12"
                                Foreground="#808080"
                                Margin="0,5,0,0"
                                TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 版权信息 -->
                    <TextBlock 
                        Grid.Row="3"
                        Text="© 2026 月见八千代"
                        FontSize="12"
                        Foreground="#808080"
                        Margin="0,20,0,0"
                        TextAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>